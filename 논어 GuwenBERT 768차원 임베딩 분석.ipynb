# ────────────────────────────────────────────────────────────
# 셀 15 — [선택] CLS vs 평균풀링 비교
# ────────────────────────────────────────────────────────────
print("=== CLS 토큰 vs 평균 풀링 군집 품질 비교 ===\n")

for emb_name, embs in [("CLS 토큰", cls_embeddings), ("평균 풀링", mean_embeddings)]:
    r5d = umap.UMAP(n_components=5, n_neighbors=10, min_dist=0.05,
                    random_state=42, metric='cosine').fit_transform(embs)
    # 최적 k 간단 탐색
    best_sil, best_k_local = -1, 5
    for k in range(4, 13):
        km = KMeans(n_clusters=k, random_state=42, n_init=20)
        labs = km.fit_predict(r5d)
        sil = silhouette_score(r5d, labs)
        if sil > best_sil:
            best_sil, best_k_local = sil, k
    # 기무라 대분류 실루엣
    sil_kim = silhouette_score(r5d, labels_maj)
    print(f"[{emb_name}]")
    print(f"  기무라 대분류 실루엣: {sil_kim:.4f}")
    print(f"  K-Means 최적 k={best_k_local}, 실루엣={best_sil:.4f}")
    print()
