import pandas as pd
import numpy as np
import torch
import matplotlib.pyplot as plt
import matplotlib.font_manager as fm
import matplotlib as mpl
import seaborn as sns
from transformers import BertTokenizer, BertModel
from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score, davies_bouldin_score, adjusted_rand_score
from sklearn.preprocessing import LabelEncoder
import umap
import hdbscan
import warnings
warnings.filterwarnings('ignore')

# ── 한글 폰트 설정 ─────────────────────────────────────
!apt-get -qq install fonts-nanum
!fc-cache -fv > /dev/null

nanum_path = '/usr/share/fonts/truetype/nanum/NanumGothic.ttf'
fm.fontManager.addfont(nanum_path)
_prop = fm.FontProperties(fname=nanum_path)

mpl.rcParams.update({
    'font.family': _prop.get_name(),
    'axes.unicode_minus': False,
})
print(f"폰트 등록 완료: {_prop.get_name()}")
# ──────────────────────────────────────────────────────

ar  = pd.read_csv('analyzed_result.csv')
kim = pd.read_csv('/content/sample_data/기무라 장군이론 5편분석.csv')

print(f"구절 수: {len(ar)}")
print(f"대분류: {list(kim['대분류'].unique())}")
print(f"소분류 수: {kim['소분류'].nunique()}")

# ────────────────────────────────────────────────────────────
# 셀 4 — GuwenBERT 모델 로드
# ────────────────────────────────────────────────────────────
MODEL_NAME = "ethanyt/guwenbert-base"

print("모델 다운로드 중... (첫 실행 시 약 400MB, 2~3분 소요)")
tokenizer = BertTokenizer.from_pretrained(MODEL_NAME)
model     = BertModel.from_pretrained(MODEL_NAME)
model.eval()

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model = model.to(device)
print(f"사용 장치: {device}")
print("모델 로드 완료")

# ────────────────────────────────────────────────────────────
# 셀 5 — 구절 임베딩 추출 (768차원 CLS + 평균풀링 두 가지)
# ────────────────────────────────────────────────────────────
def get_embeddings(text: str):
    """
    CLS 토큰 벡터와 평균 풀링 벡터를 모두 반환.
    두 방식의 군집 품질을 나중에 비교.
    """
    inputs = tokenizer(
        text,
        return_tensors="pt",
        max_length=128,
        truncation=True,
        padding=True
    ).to(device)

    with torch.no_grad():
        outputs = model(**inputs)

    # CLS 토큰 (첫 번째 토큰)
    cls_vec  = outputs.last_hidden_state[:, 0, :].squeeze().cpu().numpy()

    # 평균 풀링 (패딩 마스크 적용)
    mask = inputs['attention_mask'].unsqueeze(-1).float()
    mean_vec = (outputs.last_hidden_state * mask).sum(1) / mask.sum(1)
    mean_vec = mean_vec.squeeze().cpu().numpy()

    return cls_vec, mean_vec


print("임베딩 추출 시작... (120구절 × 약 0.3초 = 약 40초)")

cls_embeddings  = []
mean_embeddings = []
text_ids        = []

for i, row in ar.iterrows():
    text = row['Original Text']
    cls_v, mean_v = get_embeddings(text)
    cls_embeddings.append(cls_v)
    mean_embeddings.append(mean_v)
    text_ids.append(row['text ID'])

    if (i + 1) % 20 == 0:
        print(f"  {i+1}/{len(ar)} 완료")

cls_embeddings  = np.array(cls_embeddings)   # shape: (120, 768)
mean_embeddings = np.array(mean_embeddings)  # shape: (120, 768)

print(f"\n임베딩 완료: {cls_embeddings.shape}")

# 저장 (나중에 재사용)
np.save('cls_embeddings.npy',  cls_embeddings)
np.save('mean_embeddings.npy', mean_embeddings)
np.save('text_ids.npy',        np.array(text_ids))
print("임베딩 저장 완료: cls_embeddings.npy / mean_embeddings.npy")

# ────────────────────────────────────────────────────────────
# 셀 6 — UMAP 차원 축소 (2D + 5D)
# ────────────────────────────────────────────────────────────
# 재실행 시 로드
# cls_embeddings  = np.load('cls_embeddings.npy')
# mean_embeddings = np.load('mean_embeddings.npy')
# text_ids        = np.load('text_ids.npy', allow_pickle=True)

print("UMAP 차원 축소 중...")

# 2D — 시각화용
reducer_2d = umap.UMAP(
    n_components=2,
    n_neighbors=10,     # 소규모 데이터(120개)에 맞게 조정
    min_dist=0.1,
    random_state=42,
    metric='cosine'     # BERT 임베딩에 코사인 거리가 적합
)

# 5D — 군집화용 (2D보다 정보 보존 더 많음)
reducer_5d = umap.UMAP(
    n_components=5,
    n_neighbors=10,
    min_dist=0.05,
    random_state=42,
    metric='cosine'
)

# CLS 기준으로 먼저 수행 (평균풀링은 다음 셀에서 비교)
coords_2d = reducer_2d.fit_transform(cls_embeddings)
coords_5d = reducer_5d.fit_transform(cls_embeddings)

print(f"2D coords: {coords_2d.shape}")
print(f"5D coords: {coords_5d.shape}")

# 메타데이터 합치기
meta = kim[['text ID', '대분류', '소분류', '주요내용']].rename(
    columns={'text ID': 'text_id'}
)
df = pd.DataFrame({
    'text_id': text_ids,
    'x': coords_2d[:, 0],
    'y': coords_2d[:, 1]
})
df = df.merge(meta, on='text_id', how='left')
df['편'] = df['text_id'].str[2:4]

print("\n샘플:")
print(df.head(5).to_string())

# ────────────────────────────────────────────────────────────
# 셀 7 — 기무라 분류의 군집 품질 평가 (핵심)
# ────────────────────────────────────────────────────────────
le_maj = LabelEncoder()
le_min = LabelEncoder()
labels_maj = le_maj.fit_transform(df['대분류'])
labels_min = le_min.fit_transform(df['소분류'])

X_2d = coords_2d
X_5d = coords_5d

print("=" * 55)
print("기무라 분류의 의미론적 군집 품질")
print("=" * 55)
print(f"{'기준':<20} {'실루엣':>8} {'DB 지수':>10}")
print("-" * 40)

for label_name, labels in [("대분류(10개)", labels_maj), ("소분류(31개)", labels_min)]:
    s2 = silhouette_score(X_2d, labels)
    s5 = silhouette_score(X_5d, labels)
    d2 = davies_bouldin_score(X_2d, labels)
    d5 = davies_bouldin_score(X_5d, labels)
    print(f"{label_name} (2D): {s2:>8.4f} {d2:>10.4f}")
    print(f"{label_name} (5D): {s5:>8.4f} {d5:>10.4f}")
    print()

print("해석 기준: 실루엣 > 0.5 우수 / 0.25~0.5 보통 / < 0.25 불량")
print("          DB 지수: 낮을수록 응집도 높음")

# ────────────────────────────────────────────────────────────
# 셀 8 — 최적 K 탐색 (K-Means / HDBSCAN 비교)
# ────────────────────────────────────────────────────────────
print("K-Means 최적 k 탐색 (3~15)...")
results = []
for k in range(3, 16):
    km = KMeans(n_clusters=k, random_state=42, n_init=20)
    labs = km.fit_predict(X_5d)   # 5D로 군집화
    sil = silhouette_score(X_5d, labs)
    results.append({'k': k, 'silhouette': sil, 'inertia': km.inertia_})
    print(f"  k={k:2d}: 실루엣={sil:.4f}")

best_k = max(results, key=lambda r: r['silhouette'])['k']
print(f"\n최적 k = {best_k}")

# HDBSCAN
print("\nHDBSCAN 탐색...")
for min_s in [3, 5, 7, 10]:
    hdb = hdbscan.HDBSCAN(min_cluster_size=min_s, min_samples=2, metric='euclidean')
    labs_h = hdb.fit_predict(X_5d)
    n_clusters = len(set(labs_h)) - (1 if -1 in labs_h else 0)
    n_noise    = (labs_h == -1).sum()
    if n_clusters > 1:
        sil_h = silhouette_score(X_5d[labs_h != -1], labs_h[labs_h != -1])
        print(f"  min_cluster_size={min_s}: {n_clusters}개 군집, 노이즈={n_noise}, 실루엣={sil_h:.4f}")
    else:
        print(f"  min_cluster_size={min_s}: 군집 미형성")

# ────────────────────────────────────────────────────────────
# 셀 9 — 기무라 분류와 최적 K-Means 비교
# ────────────────────────────────────────────────────────────
km_best = KMeans(n_clusters=best_k, random_state=42, n_init=20)
df['km_cluster'] = km_best.fit_predict(X_5d)

ari_maj = adjusted_rand_score(labels_maj, df['km_cluster'])
ari_min = adjusted_rand_score(labels_min, df['km_cluster'])

print(f"K-Means(k={best_k}) vs 기무라 대분류  ARI: {ari_maj:.4f}")
print(f"K-Means(k={best_k}) vs 기무라 소분류  ARI: {ari_min:.4f}")
print("(ARI: 1=완전일치, 0=무작위, 음수=역상관)\n")

print("=== 교차표: 기무라 대분류 vs K-Means 군집 ===")
ct = pd.crosstab(df['대분류'], df['km_cluster'])
print(ct.to_string())

# ────────────────────────────────────────────────────────────
# 셀 10 — 군집별 대표 구절 출력 (해석 참고용)
# ────────────────────────────────────────────────────────────
ar_ref = ar[['text ID', 'Original Text', '주요내용']].rename(
    columns={'text ID': 'text_id'}
)
df_full = df.merge(ar_ref, on='text_id', how='left')

print("=== K-Means 군집별 구절 목록 ===\n")
for c in range(best_k):
    sub = df_full[df_full['km_cluster'] == c].sort_values('text_id')
    maj_dist = sub['대분류'].value_counts().to_dict()
    print(f"── 군집 {c} (n={len(sub)}) | 기무라 대분류 분포: {maj_dist}")
    for _, row in sub.iterrows():
        print(f"   {row['text_id']}  [{row['대분류']}/{row['소분류']}]  {row['주요내용_y']}")
        print(f"          {row['Original Text'][:50]}")
    print()

# ────────────────────────────────────────────────────────────
# 셀 11 — 시각화 1: 기무라 대분류 색상 산점도
# ────────────────────────────────────────────────────────────
fig, axes = plt.subplots(1, 2, figsize=(16, 7))

COLORS_MAJ = {
    '01A': '#3266ad', '02A': '#1D9E75', '02B': '#5DCAA5',
    '03A': '#D85A30', '03B': '#F0997B',
    '04A': '#D4537E', '04B': '#ED93B1',
    '05A': '#BA7517', '05B': '#EF9F27', '05C': '#FAC775'
}

# 왼쪽: 기무라 대분류
ax = axes[0]
for maj, grp in df.groupby('대분류'):
    ax.scatter(grp['x'], grp['y'],
               c=COLORS_MAJ.get(maj, '#888'),
               label=maj, s=60, alpha=0.85, edgecolors='white', linewidths=0.4)
    # 중심 레이블
    cx, cy = grp['x'].mean(), grp['y'].mean()
    ax.annotate(maj, (cx, cy), fontsize=8, fontweight='bold',
                ha='center', va='center',
                bbox=dict(boxstyle='round,pad=0.2', fc='white', alpha=0.7, ec='none'))

ax.set_title('기무라 대분류 (UMAP 2D)', fontsize=13)
ax.legend(loc='upper right', fontsize=8, markerscale=0.9)
ax.set_xlabel('UMAP 1'); ax.set_ylabel('UMAP 2')
ax.grid(True, alpha=0.15)

# 오른쪽: K-Means 군집
ax2 = axes[1]
km_colors = plt.cm.Set2(np.linspace(0, 1, best_k))
for c in range(best_k):
    grp = df[df['km_cluster'] == c]
    ax2.scatter(grp['x'], grp['y'],
                c=[km_colors[c]], label=f'군집{c}',
                s=60, alpha=0.85, edgecolors='white', linewidths=0.4)
    cx, cy = grp['x'].mean(), grp['y'].mean()
    ax2.annotate(str(c), (cx, cy), fontsize=9, fontweight='bold', ha='center')

ax2.set_title(f'K-Means 군집 (k={best_k})', fontsize=13)
ax2.legend(loc='upper right', fontsize=8, markerscale=0.9)
ax2.set_xlabel('UMAP 1'); ax2.set_ylabel('UMAP 2')
ax2.grid(True, alpha=0.15)

plt.suptitle('GuwenBERT 768차원 임베딩 — 기무라 분류 vs 의미론적 군집', fontsize=14)
plt.tight_layout()
plt.savefig('umap_comparison.png', dpi=150, bbox_inches='tight')
plt.show()
print("저장: umap_comparison.png")
plt.rcParams['font.family'] = _prop.get_name()

# ────────────────────────────────────────────────────────────
# 셀 12 — 시각화 2: 구절 레이블 산점도 (인터랙티브)
# ────────────────────────────────────────────────────────────
fig, ax = plt.subplots(figsize=(14, 10))

for maj, grp in df.groupby('대분류'):
    ax.scatter(grp['x'], grp['y'],
               c=COLORS_MAJ.get(maj, '#888'),
               s=55, alpha=0.8, edgecolors='white', linewidths=0.4,
               label=maj, zorder=3)

# 각 점에 text_id 표시
for _, row in df.iterrows():
    ax.annotate(
        row['text_id'],
        (row['x'], row['y']),
        fontsize=6.5,
        xytext=(3, 3), textcoords='offset points',
        color='#333', alpha=0.8
    )

ax.set_title('논어 구절 임베딩 공간 (GuwenBERT 768차원 → UMAP 2D)\n기무라 대분류 색상', fontsize=13)
ax.legend(bbox_to_anchor=(1.01, 1), loc='upper left', fontsize=9)
ax.grid(True, alpha=0.12)
plt.tight_layout()
plt.savefig('umap_labeled.png', dpi=150, bbox_inches='tight')
plt.show()
print("저장: umap_labeled.png")
plt.rcParams['font.family'] = _prop.get_name()

# ────────────────────────────────────────────────────────────
# 셀 13 — 시각화 3: 실루엣 히트맵 (기무라 대분류 내부 응집도)
# ────────────────────────────────────────────────────────────
from sklearn.metrics import pairwise_distances

# 대분류별 내부 응집도 (평균 코사인 유사도)
print("=== 대분류별 내부 응집도 (평균 코사인 유사도) ===")
cohesion = {}
# Iterate over the string representation of unique categories
for maj_str in sorted(df['대분류'].astype(str).unique()):
    # Filter using the string representation for consistency
    idx = df[df['대분류'].astype(str) == maj_str].index
    vecs = cls_embeddings[idx]
    if len(vecs) > 1:
        from sklearn.metrics.pairwise import cosine_similarity
        sim_mat = cosine_similarity(vecs)
        np.fill_diagonal(sim_mat, 0)
        avg_sim = sim_mat.sum() / (len(vecs) * (len(vecs) - 1))
    else:
        # If there's 0 or 1 sample in a category, cohesion is considered 1.0 (perfectly cohesive)
        avg_sim = 1.0
    cohesion[maj_str] = round(avg_sim, 4)
    print(f"  {maj_str}: {avg_sim:.4f}")

print()
print("=== 대분류 간 분리도 (평균 코사인 유사도) ===")
maj_list = sorted(df['대분류'].astype(str).unique())
sep_mat = np.zeros((len(maj_list), len(maj_list)))

for i, m1_str in enumerate(maj_list):
    for j, m2_str in enumerate(maj_list):
        if i != j:
            # Filter using the string representation for consistency
            idx1 = df[df['대분류'].astype(str) == m1_str].index
            idx2 = df[df['대분류'].astype(str) == m2_str].index

            # Only compute cosine_similarity if both groups have samples
            if len(idx1) > 0 and len(idx2) > 0:
                from sklearn.metrics.pairwise import cosine_similarity
                sim = cosine_similarity(cls_embeddings[idx1], cls_embeddings[idx2])
                sep_mat[i, j] = round(sim.mean(), 4)
            else:
                # If comparison is not possible (one or both groups are empty), assign NaN
                sep_mat[i, j] = np.nan

sep_df = pd.DataFrame(sep_mat, index=maj_list, columns=maj_list)

fig, axes = plt.subplots(1, 2, figsize=(16, 6))

# 내부 응집도 막대그래프
ax1 = axes[0]
maj_names = list(cohesion.keys())
vals = [cohesion[m] for m in maj_names]
bars = ax1.bar(maj_names, vals,
               color=[COLORS_MAJ.get(m, '#888') for m in maj_names],
               edgecolor='white', linewidth=0.5)
ax1.axhline(np.mean(vals), color='gray', linestyle='--', linewidth=1, label=f'평균={np.mean(vals):.3f}')
ax1.set_title('대분류별 내부 응집도\n(높을수록 그룹 내 구절이 의미론적으로 가까움)', fontsize=11)
ax1.set_ylabel('평균 코사인 유사도')
ax1.set_ylim(0, 1)
ax1.legend()
for bar, val in zip(bars, vals):
    ax1.text(bar.get_x() + bar.get_width()/2, val + 0.01,
             f'{val:.3f}', ha='center', va='bottom', fontsize=8)

# 대분류 간 유사도 히트맵
ax2 = axes[1]
sns.heatmap(sep_df, annot=True, fmt='.3f', cmap='RdYlGn_r',
            linewidths=0.5, ax=ax2, vmin=0.85, vmax=1.0,
            annot_kws={'size': 8})
ax2.set_title('대분류 간 의미론적 유사도\n(높을수록 두 분류가 구분되지 않음)', fontsize=11)

plt.suptitle('기무라 대분류의 의미론적 응집도 분석', fontsize=13)
plt.tight_layout()
plt.savefig('cohesion_analysis.png', dpi=150, bbox_inches='tight')
plt.show()
print("저장: cohesion_analysis.png")
plt.rcParams['font.family'] = _prop.get_name()

# ────────────────────────────────────────────────────────────
# 셀 14 — 결과 CSV 저장
# ────────────────────────────────────────────────────────────
# 각 구절에 임베딩 좌표 + K-Means 군집 레이블 붙인 최종 파일
result_df = df_full.copy()
result_df['umap_x'] = coords_2d[:, 0]
result_df['umap_y'] = coords_2d[:, 1]

# 임베딩 벡터도 저장 (768차원 → 컬럼명 emb_0 ~ emb_767)
emb_df = pd.DataFrame(
    cls_embeddings,
    columns=[f'emb_{i}' for i in range(cls_embeddings.shape[1])]
)
emb_df['text_id'] = text_ids

result_df = result_df.merge(emb_df, on='text_id', how='left')
result_df.to_csv('guwenbert_768_result.csv', index=False, encoding='utf-8-sig')
